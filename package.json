{
  "name": "bradley-health",
  "version": "1.0.0",
  "description": "Bradley Health - Medical Monitoring Application",
  "main": "index.js",
  "scripts": {
    "start": "firebase serve",
    "build": "firebase deploy",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "stylelint": "stylelint \"**/*.css\"",
    "stylelint:fix": "stylelint \"**/*.css\" --fix",
    "css:build": "postcss assets/style.css -o dist/style.min.css",
    "css:watch": "postcss assets/style.css -o dist/style.min.css --watch",
    "a11y": "pa11y-ci",
    "check": "node scripts/fix-errors.js",
    "fix": "node scripts/fix-errors.js --fix"
  },
  "dependencies": {
    "chart.js": "^4.4.1",
    "firebase": "^10.8.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.7.0",
    "moment": "^2.30.1",
    "node-fetch": "^2.7.0",
    "sweetalert2": "^11.10.5",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "autoprefixer": "^10.4.21",
    "babel-jest": "^29.7.0",
    "eslint": "^8.56.0",
    "firebase-tools": "^13.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.5.4",
    "postcss-cli": "^11.0.1",
    "postcss-preset-env": "^10.2.2",
    "prettier": "^3.5.3",
    "stylelint": "^16.20.0",
    "stylelint-config-standard": "^38.0.0",
    "pa11y-ci": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "private": true
}
